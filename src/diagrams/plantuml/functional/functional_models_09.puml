@startuml
left to right direction
actor "Студент" as S
rectangle "1. Запрос рекомендаций" as P1
rectangle "2. Расчёт score" as P2
rectangle "3. Формирование выдачи" as P3
database "D1 Профили" as D1
database "D2 Вакансии" as D2
database "D3 История откликов" as D3
database "D4 Кэш рекомендаций" as D4
S --> P1 : открыть рекомендации
P1 --> D4 : проверить кэш
P1 --> P2 : если кэша нет
P2 --> D1
P2 --> D2
P2 --> D3
P2 --> P3 : вакансии + score
P3 --> D4 : сохранить результат
P3 --> S : топ рекомендаций
@enduml
